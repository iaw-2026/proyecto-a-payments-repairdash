DATABASE_URL=

# Clerk web auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard

# App public URL used to build redirects and webhook/callback URLs
APP_URL=

# Rider App web home/dashboard URL used by checkout result buttons
NEXT_PUBLIC_RIDER_APP_URL=

# Server-to-server auth. Do not replace this with Clerk JWTs.
PAYMENTS_INTERNAL_API_KEY=

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=

# Callback from Payments App to Rider App
RIDER_PAYMENT_CALLBACK_URL=
# Shared RepairDash API key used as x-api-key for Rider App callbacks.
REPAIRDASH_API_KEY=
# Backward-compatible fallback for local/dev envs that still use the old name.
RIDER_CALLBACK_API_KEY=
