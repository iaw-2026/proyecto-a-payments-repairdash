// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionStatus {
  PENDING
  RESERVED
  LIQUIDATED
  DISPUTED
  REFUNDED
  FAILED
}

model User {
  clerkId   String @id
  email     String @unique
  fullName  String
  role      String
  cliente   Cliente?
  trabajador Trabajador?
}

model Cliente {
  clerkId String @id
  user    User   @relation(fields: [clerkId], references: [clerkId])
}

model Trabajador {
  clerkId      String  @id
  cbuCvu       String?
  user         User    @relation(fields: [clerkId], references: [clerkId])
  balance      Balance?
  withdrawals  Withdrawal[]
}

model Transaction {
  id                  String            @id
  trabajoId           String            @unique
  amount              Decimal           @db.Decimal(12,2)
  status              TransactionStatus
  clientId            String?
  trabajadorId        String
  gatewayPreferenceId String?
  gatewayCheckoutUrl  String?
  gatewayPaymentId    String?
  createdAt           DateTime          @default(now())
  reservedAt          DateTime?
  liquidatedAt        DateTime?
  commissionRate      Decimal?          @db.Decimal(5,2)
  commissionAmount    Decimal?          @db.Decimal(12,2)
  netAmount           Decimal?          @db.Decimal(12,2)

  @@index([clientId, createdAt], name: "idx_transaction_client_created_at")
  @@index([clientId, status, createdAt], name: "idx_transaction_client_status_created_at")
  @@index([trabajadorId, createdAt], name: "idx_transaction_trabajador_created_at")
  @@index([trabajadorId, status, liquidatedAt, createdAt], name: "idx_transaction_trabajador_status_liquidated_created_at")
  @@index([status, createdAt], name: "idx_transaction_status_created_at")
  @@index([createdAt], name: "idx_transaction_created_at")
}

model CommissionSettings {
  id             String   @id
  commissionRate Decimal  @db.Decimal(5,2)
  updatedAt      DateTime @updatedAt
}

model Balance {
  trabajadorId      String   @id
  trabajador        Trabajador @relation(fields: [trabajadorId], references: [clerkId])
  balanceAvailable  Decimal  @db.Decimal(12,2)
  balanceLocked     Decimal  @db.Decimal(12,2)
  updatedAt         DateTime @updatedAt
}

enum WithdrawalStatus {
  REQUESTED
  APPROVED
  REJECTED
}

model Withdrawal {
  id            String            @id
  trabajadorId  String
  amount        Decimal           @db.Decimal(12,2)
  status        WithdrawalStatus  @default(REQUESTED)
  createdAt     DateTime          @default(now())
  trabajador    Trabajador        @relation(fields: [trabajadorId], references: [clerkId])

  @@index([trabajadorId, createdAt], name: "idx_withdrawal_trabajador_created_at")
  @@index([status, createdAt], name: "idx_withdrawal_status_created_at")
  @@index([createdAt], name: "idx_withdrawal_created_at")
}
